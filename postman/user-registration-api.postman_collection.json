{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "User Registration API",
    "description": "Postman Collection for User Registration API testing. Contains Create, Get, and Delete user requests with test scripts and variable chaining for Collection Runner execution.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userEmail",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phoneNumber\": \"1234567890\",\n  \"password\": \"SecurePass123\",\n  \"confirmPassword\": \"SecurePass123\",\n  \"dateOfBirth\": \"1990-05-15\",\n  \"age\": 34,\n  \"gender\": \"Male\",\n  \"nationality\": \"American\",\n  \"employeeId\": \"EMP001\",\n  \"isActive\": true,\n  \"address\": {\n    \"addressLine1\": \"123 Main Street\",\n    \"addressLine2\": \"Apt 4B\",\n    \"city\": \"New York\",\n    \"state\": \"NY\",\n    \"country\": \"USA\"\n  },\n  \"skills\": [\"JavaScript\", \"TypeScript\", \"Node.js\", \"API Testing\"]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "register"]
        },
        "description": "Creates a new user with all User_Model fields. On success, sets userId and userEmail environment variables for subsequent requests."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Validate status code is 201",
              "pm.test('Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// Validate response body contains a non-null user ID",
              "pm.test('Response body contains user ID', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('id');",
              "    pm.expect(jsonData.data.id).to.not.be.null;",
              "});",
              "",
              "// Validate response time is below 2000ms",
              "pm.test('Response time is below 2000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// Set userId and userEmail variables from response for subsequent requests",
              "var jsonData = pm.response.json();",
              "if (jsonData.data && jsonData.data.id) {",
              "    pm.collectionVariables.set('userId', jsonData.data.id.toString());",
              "}",
              "if (jsonData.data && jsonData.data.email) {",
              "    pm.collectionVariables.set('userEmail', jsonData.data.email);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "{{userId}}"]
        },
        "description": "Retrieves user details by ID. Uses the userId variable set by the Create User request."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Validate status code is 200",
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Validate response body contains expected fields",
              "pm.test('Response body contains firstName', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('firstName');",
              "});",
              "",
              "pm.test('Response body contains lastName', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('lastName');",
              "});",
              "",
              "pm.test('Response body contains email', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('email');",
              "});",
              "",
              "pm.test('Response body contains phoneNumber', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('phoneNumber');",
              "});",
              "",
              "pm.test('Response body contains address', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('address');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "{{userId}}"]
        },
        "description": "Deletes a user by ID. Uses the userId variable set by the Create User request."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Validate status code is 200",
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Validate response body contains message field",
              "pm.test('Response body contains message field', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('message');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}